{
  "name": "data-anim-inspector",
  "version": "1.0.0",
  "description": "Click any element on a website and try data-anim animations. Available as a script tag or Chrome extension.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build && vite build --config vite.config.extension.ts",
    "build:script": "vite build",
    "build:extension": "vite build --config vite.config.extension.ts",
    "dev": "vite build --watch"
  },
  "keywords": [
    "data-anim",
    "animation",
    "inspector",
    "chrome-extension",
    "devtools"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  }
}
