{
  "manifest_version": 3,
  "name": "data-anim Inspector",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "1.0.0",
  "homepage_url": "https://ryo-manba.github.io/data-anim/",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Toggle data-anim Inspector"
  },
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  }
}
