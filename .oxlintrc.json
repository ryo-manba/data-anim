{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": ["typescript"],
  "rules": {
    "eslint/no-unused-vars": "error"
  },
  "overrides": [
    {
      "files": ["tests/**"],
      "rules": {
        "eslint/no-console": "off"
      }
    }
  ]
}
