---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Footer from '../components/Footer.astro';

const categories = [
  {
    name: 'Fade',
    desc: 'Smooth opacity transitions with optional directional movement.',
    anims: ['fadeIn', 'fadeInUp', 'fadeInDown', 'fadeInLeft', 'fadeInRight'],
    color: 'from-violet-500 to-indigo-500',
    span: 'md:col-span-2',
  },
  {
    name: 'Slide',
    desc: 'Full-width entrance animations from any direction.',
    anims: ['slideInUp', 'slideInDown', 'slideInLeft', 'slideInRight'],
    color: 'from-blue-500 to-cyan-400',
    span: '',
  },
  {
    name: 'Zoom',
    desc: 'Scale-based entrances for impactful reveals.',
    anims: ['zoomIn', 'zoomOut', 'zoomInUp', 'zoomInDown'],
    color: 'from-emerald-500 to-teal-400',
    span: '',
  },
  {
    name: 'Bounce',
    desc: 'Playful multi-step animations with overshoot.',
    anims: ['bounce', 'bounceIn', 'bounceInUp', 'bounceInDown'],
    color: 'from-amber-500 to-orange-400',
    span: 'md:col-span-2',
  },
  {
    name: 'Attention',
    desc: 'In-place effects for drawing the eye. Perfect for hover and click.',
    anims: ['shake', 'pulse', 'wobble', 'flip', 'swing', 'rubberBand'],
    color: 'from-pink-500 to-rose-400',
    span: 'md:col-span-2',
  },
  {
    name: 'Rotate & Special',
    desc: 'Rotation entrances, blur reveals, and more.',
    anims: ['rotateIn', 'blur', 'clipReveal', 'typewriter'],
    color: 'from-fuchsia-500 to-purple-500',
    span: '',
  },
];
---

<BaseLayout title="data-anim — Zero-JS Animation Library">
  <Header />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-heading font-bold mb-6" data-anim="fadeInUp">
        Animate with <span class="gradient-text">zero JavaScript</span>
      </h1>
      <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-8" data-anim="fadeInUp" data-anim-delay="100ms">
        Drop-in scroll animations using HTML attributes. Built-in anti-FOUC protection. Under 2KB. No dependencies.
      </p>

      <!-- Install one-liner -->
      <div class="inline-flex items-center gap-3 bg-code-bg border border-border rounded-lg px-5 py-3 mb-8" data-anim="fadeInUp" data-anim-delay="200ms">
        <code class="font-mono text-sm text-text-secondary">
          <span class="text-text-muted">$</span> npm install data-anim
        </code>
        <button id="copy-install" class="text-text-muted hover:text-text transition-colors" aria-label="Copy install command">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
          </svg>
        </button>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-anim="fadeInUp" data-anim-delay="300ms">
        <a href={`${import.meta.env.BASE_URL}docs/getting-started`} class="btn-primary">
          Get Started
        </a>
        <a href={`${import.meta.env.BASE_URL}playground`} class="btn-secondary">
          Playground
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-4 sm:px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-anim-stagger="100ms">
        <div class="glass-card p-6" data-anim="fadeInUp">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading font-semibold mb-2">Zero JavaScript</h3>
          <p class="text-sm text-text-secondary">Pure CSS animations triggered by HTML attributes. No runtime JS after initialization.</p>
        </div>

        <div class="glass-card p-6" data-anim="fadeInUp">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading font-semibold mb-2">Anti-FOUC Built-in</h3>
          <p class="text-sm text-text-secondary">3-layer defense against Flash of Unstyled Content. No manual CSS workarounds needed.</p>
        </div>

        <div class="glass-card p-6" data-anim="fadeInUp">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
          </div>
          <h3 class="text-lg font-heading font-semibold mb-2">Under 2KB</h3>
          <p class="text-sm text-text-secondary">Tiny footprint. No dependencies. Loads in under 5ms. Smaller than most favicons.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="py-20 px-4 sm:px-6 border-t border-border">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-heading font-bold text-center mb-4" data-anim="fadeInUp">
        Three lines. That's it.
      </h2>
      <p class="text-center text-text-secondary mb-8" data-anim="fadeInUp" data-anim-delay="100ms">
        No config files. No build step. No framework required.
      </p>

      <div data-anim="fadeInUp" data-anim-delay="200ms">
        <CodeBlock
          code={`<!-- 1. Add the script -->
<script src="https://unpkg.com/data-anim@latest/dist/data-anim.js"></script>

<!-- 2. Add the attribute -->
<div data-anim="fadeInUp">
  Your content animates on scroll
</div>

<!-- 3. There is no step 3 -->`}
          lang="html"
          filename="index.html"
        />
      </div>

      <div class="text-center mt-8" data-anim="fadeInUp" data-anim-delay="300ms">
        <a href={`${import.meta.env.BASE_URL}docs/getting-started`} class="text-accent hover:text-accent-light font-semibold text-lg">
          Read the full docs &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Animation Showcase -->
  <section class="py-20 px-4 sm:px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <p class="text-center text-xs font-semibold tracking-widest text-text-muted uppercase mb-4" data-anim="fadeInUp">Animation Library</p>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-center mb-4" data-anim="fadeInUp">
        30+ built-in animations
      </h2>
      <p class="text-center text-text-secondary mb-12 max-w-xl mx-auto" data-anim="fadeInUp" data-anim-delay="100ms">
        From subtle fades to playful bounces. Every animation is GPU-accelerated and respects <code class="text-accent-light">prefers-reduced-motion</code>.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {categories.map((cat) => (
          <div class={`showcase-card glass-card overflow-hidden ${cat.span}`} data-anim="fadeInUp" data-anim-once>
            <!-- Preview area -->
            <div class="showcase-preview">
              <div class="flex flex-wrap gap-2 justify-center">
                {cat.anims.map((anim) => (
                  <div
                    class={`showcase-dot bg-gradient-to-br ${cat.color}`}
                    data-anim={anim}
                    data-anim-trigger="hover"
                  />
                ))}
              </div>
            </div>
            <!-- Info -->
            <div class="p-5">
              <h3 class="text-base font-heading font-semibold mb-1">{cat.name}</h3>
              <p class="text-sm text-text-secondary mb-3">{cat.desc}</p>
              <div class="flex flex-wrap gap-1.5">
                {cat.anims.map((anim) => (
                  <code class="text-[11px] font-mono px-1.5 py-0.5 rounded bg-bg-surface text-text-muted">{anim}</code>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10" data-anim="fadeInUp">
        <a href={`${import.meta.env.BASE_URL}docs/animations`} class="text-accent hover:text-accent-light font-semibold text-lg">
          Browse all animations &rarr;
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
    color: #fff;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-primary:hover {
    background: linear-gradient(135deg, #818cf8, #c084fc);
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
    color: #fff;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    background-color: var(--color-bg-hover);
    color: var(--color-text);
  }

  .showcase-card {
    display: flex;
    flex-direction: column;
  }

  .showcase-preview {
    padding: 2rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 140px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 100%);
  }

  .showcase-dot {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    cursor: pointer;
    transition: box-shadow 0.2s;
  }
  .showcase-dot:hover {
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
  }
</style>

<script>
  document.getElementById('copy-install')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('npm install data-anim');
    const btn = document.getElementById('copy-install')!;
    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
    setTimeout(() => {
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
    }, 2000);
  });
</script>
