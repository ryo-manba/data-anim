---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;

const sections = [
  {
    title: 'Getting Started',
    links: [
      { href: `${base}docs/getting-started`, label: 'Installation & Setup' },
    ],
  },
  {
    title: 'Core Concepts',
    links: [
      { href: `${base}docs/attributes`, label: 'Attributes' },
      { href: `${base}docs/animations`, label: 'Animations' },
      { href: `${base}docs/triggers`, label: 'Triggers' },
      { href: `${base}docs/stagger`, label: 'Stagger' },
    ],
  },
  {
    title: 'Advanced',
    links: [
      { href: `${base}docs/responsive`, label: 'Responsive' },
      { href: `${base}docs/anti-fouc`, label: 'Anti-FOUC' },
    ],
  },
  {
    title: 'Guides',
    links: [
      { href: `${base}docs/integration`, label: 'Integration' },
    ],
  },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href + '/';
}

function isSectionActive(links: { href: string }[]): boolean {
  return links.some(link => isActive(link.href));
}
---

<aside class="w-[260px] shrink-0 hidden lg:block">
  <nav class="sticky top-20 overflow-y-auto max-h-[calc(100vh-5rem)] pb-8 pr-4">
    {sections.map((section) => (
      <details open={isSectionActive(section.links) || true} class="mb-4">
        <summary class="text-sm font-semibold uppercase tracking-wider text-text-secondary mb-2 py-1">
          {section.title}
        </summary>
        <ul class="space-y-1 ml-3">
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block text-[15px] py-1.5 px-3 rounded-md no-underline transition-colors',
                  isActive(link.href)
                    ? 'bg-accent/10 border-l-2 border-accent font-medium sidebar-active'
                    : 'text-text hover:text-accent-readable hover:bg-bg-hover',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</aside>
