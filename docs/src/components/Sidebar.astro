---
import { getLocaleFromPath, getLocalizedPath, translations } from '../i18n/translations';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const t = translations[locale].sidebar;

const sections = [
  {
    title: t.gettingStarted,
    links: [
      { href: getLocalizedPath('docs/getting-started', locale, base), label: t.installationSetup },
    ],
  },
  {
    title: t.coreConcepts,
    links: [
      { href: getLocalizedPath('docs/animations', locale, base), label: t.animations },
      { href: getLocalizedPath('docs/triggers', locale, base), label: t.triggers },
      { href: getLocalizedPath('docs/stagger', locale, base), label: t.stagger },
      { href: getLocalizedPath('docs/attributes', locale, base), label: t.attributes },
    ],
  },
  {
    title: t.advanced,
    links: [
      { href: getLocalizedPath('docs/responsive', locale, base), label: t.responsive },
      { href: getLocalizedPath('docs/anti-fouc', locale, base), label: t.antiFouc },
    ],
  },
  {
    title: t.guides,
    links: [
      { href: getLocalizedPath('docs/typescript', locale, base), label: t.typescript },
      { href: getLocalizedPath('docs/integration', locale, base), label: t.integration },
    ],
  },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href + '/';
}

function isSectionActive(links: { href: string }[]): boolean {
  return links.some(link => isActive(link.href));
}
---

<!-- Mobile sidebar overlay -->
<div id="sidebar-overlay" class="lg:hidden fixed inset-0 z-40 bg-black/50 hidden" aria-hidden="true"></div>

<!-- Mobile sidebar -->
<aside id="mobile-sidebar" class="lg:hidden fixed top-16 left-0 bottom-0 z-40 w-[280px] bg-bg border-r border-border -translate-x-full transition-transform duration-200 overflow-y-auto">
  <nav class="p-4 pb-8">
    {sections.map((section) => (
      <details open={isSectionActive(section.links) || true} class="mb-4">
        <summary class="text-sm font-semibold uppercase tracking-wider text-text-secondary mb-2 py-1">
          {section.title}
        </summary>
        <ul class="space-y-1 ml-3">
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block text-[15px] py-1.5 px-3 rounded-md no-underline transition-colors',
                  isActive(link.href)
                    ? 'bg-accent/10 border-l-2 border-accent font-medium sidebar-active'
                    : 'text-text hover:text-accent-readable hover:bg-bg-hover',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</aside>

<!-- Desktop sidebar -->
<aside class="w-[260px] shrink-0 hidden lg:block">
  <nav class="sticky top-20 overflow-y-auto max-h-[calc(100vh-5rem)] pb-8 pr-4">
    {sections.map((section) => (
      <details open={isSectionActive(section.links) || true} class="mb-4">
        <summary class="text-sm font-semibold uppercase tracking-wider text-text-secondary mb-2 py-1">
          {section.title}
        </summary>
        <ul class="space-y-1 ml-3">
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block text-[15px] py-1.5 px-3 rounded-md no-underline transition-colors',
                  isActive(link.href)
                    ? 'bg-accent/10 border-l-2 border-accent font-medium sidebar-active'
                    : 'text-text hover:text-accent-readable hover:bg-bg-hover',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </nav>
</aside>

<script>
  function initSidebar() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('mobile-sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    if (!toggle || !sidebar || !overlay) return;

    function open() {
      sidebar!.classList.remove('-translate-x-full');
      overlay!.classList.remove('hidden');
      toggle!.querySelector('svg')!.style.transform = 'rotate(90deg)';
    }

    function close() {
      sidebar!.classList.add('-translate-x-full');
      overlay!.classList.add('hidden');
      toggle!.querySelector('svg')!.style.transform = '';
    }

    toggle.addEventListener('click', () => {
      const isOpen = !sidebar!.classList.contains('-translate-x-full');
      isOpen ? close() : open();
    });

    overlay.addEventListener('click', close);
  }

  initSidebar();
  document.addEventListener('astro:after-swap', initSidebar);
</script>
