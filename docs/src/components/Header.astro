---
import { getLocaleFromPath, getLocalizedPath, translations } from '../i18n/translations';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const t = translations[locale].nav;
const altLocale = locale === 'en' ? 'ja' : 'en';

// Build the alternate locale path
function getAltLocalePath(): string {
  const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '');
  let path = currentPath.replace(basePath, '');
  if (locale === 'ja') {
    path = path.replace(/^\/ja/, '');
  }
  if (!path || path === '/') path = '';
  if (altLocale === 'ja') {
    return `${base}ja${path}`;
  }
  return `${base}${path.replace(/^\//, '')}` || base;
}

const altPath = getAltLocalePath();
const langLabel = locale === 'en' ? '日本語' : 'English';
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href={locale === 'ja' ? `${base}ja/` : base} class="flex items-center gap-2 text-text hover:text-text no-underline">
      <svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
        <defs>
          <linearGradient id="logo-g1" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#818cf8"/>
            <stop offset="100%" stop-color="#c084fc"/>
          </linearGradient>
          <linearGradient id="logo-g2" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#c084fc"/>
            <stop offset="100%" stop-color="#f472b6"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="7" fill="#0a0a1f"/>
        <rect x="9" y="9" width="14" height="14" rx="4" fill="url(#logo-g2)" opacity="0.15" transform="translate(4, -3)"/>
        <rect x="9" y="9" width="14" height="14" rx="4" fill="url(#logo-g1)" opacity="0.4" transform="translate(2, -1.5)"/>
        <rect x="9" y="9" width="14" height="14" rx="4" fill="url(#logo-g1)"/>
      </svg>
      <span class="font-heading font-bold text-xl gradient-text">data-anim</span>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      <a
        href={getLocalizedPath('docs/getting-started', locale, base)}
        class:list={['text-sm font-medium transition-colors no-underline', currentPath.includes('/docs') ? 'text-text' : 'text-text-secondary hover:text-text']}
      >
        {t.docs}
      </a>
      <a
        href={getLocalizedPath('playground', locale, base)}
        class:list={['text-sm font-medium transition-colors no-underline', currentPath.includes('/playground') ? 'text-text' : 'text-text-secondary hover:text-text']}
      >
        {t.playground}
      </a>
      <a
        href="https://www.npmjs.com/package/data-anim"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors no-underline"
      >
        npm
      </a>
      <a
        href="https://github.com/ryo-manba/data-anim"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors no-underline"
      >
        GitHub
      </a>
      <a
        href={altPath}
        class="text-sm font-medium text-text-secondary hover:text-text transition-colors no-underline border-l border-border pl-6"
      >
        {langLabel}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-secondary hover:text-text"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-bg/95 backdrop-blur-md">
    <nav class="flex flex-col p-4 gap-3">
      <a href={getLocalizedPath('docs/getting-started', locale, base)} class="text-sm font-medium text-text-secondary hover:text-text no-underline">{t.docs}</a>
      <a href={getLocalizedPath('playground', locale, base)} class="text-sm font-medium text-text-secondary hover:text-text no-underline">{t.playground}</a>
      <a href="https://www.npmjs.com/package/data-anim" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-text-secondary hover:text-text no-underline">npm</a>
      <a href="https://github.com/ryo-manba/data-anim" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-text-secondary hover:text-text no-underline">GitHub</a>
      <a href={altPath} class="text-sm font-medium text-text-secondary hover:text-text no-underline border-t border-border pt-3">{langLabel}</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
