---
interface Props {
  name: string;
  trigger?: string;
}

const { name, trigger } = Astro.props;
const id = `demo-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="glass-card p-4 mb-4">
  <div class="flex items-center justify-between mb-3">
    <code class="text-xs font-mono text-accent">{name}</code>
    {trigger && <span class="text-xs text-text-muted">trigger: {trigger}</span>}
    <button
      class="demo-play-btn text-xs px-3 py-1 rounded border border-border text-text-secondary hover:text-text hover:border-accent hover:bg-accent/10 transition-colors"
      data-target={id}
      data-anim-name={name}
    >
      Play
    </button>
  </div>
  <div class="flex items-center justify-center h-24 rounded-lg bg-bg-surface border border-border overflow-hidden">
    <div
      id={id}
      class="w-16 h-16 rounded-lg"
      style="background: linear-gradient(135deg, #4f46e5, #7c3aed);"
    >
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.demo-play-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const animName = btn.getAttribute('data-anim-name');
      const el = document.getElementById(targetId!);
      if (el && animName) {
        el.style.animation = 'none';
        el.offsetWidth;
        el.style.animation = `da-${animName} 1s ease both`;
        el.addEventListener('animationend', () => {
          el.style.animation = '';
        }, { once: true });
      }
    });
  });
</script>
