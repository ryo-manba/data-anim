---
interface Props {
  name: string;
  trigger?: string;
}

const { name, trigger } = Astro.props;
const id = `demo-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="demo-card">
  <div class="demo-header">
    <code class="demo-label">{name}</code>
    <button class="demo-play-btn" data-demo-id={id} data-demo-anim={name}>Play</button>
  </div>
  <div class="demo-stage">
    <div id={id} class="demo-box"></div>
  </div>
</div>

<style>
  .demo-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .demo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 14px;
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
  }
  .demo-label {
    font-family: var(--font-mono) !important;
    font-size: 14px !important;
    color: var(--color-accent-readable) !important;
    background: none !important;
    padding: 0 !important;
  }
  .demo-play-btn {
    padding: 4px 14px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: none;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .demo-play-btn:hover {
    border-color: var(--color-accent-readable);
    color: var(--color-accent-readable);
    background: rgba(99, 102, 241, 0.05);
  }
  .demo-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 120px;
    overflow: hidden;
  }
  .demo-box {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
  }
</style>

<script is:inline>
  document.querySelectorAll('.demo-play-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = btn.getAttribute('data-demo-id');
      var name = btn.getAttribute('data-demo-anim');
      var el = document.getElementById(id);
      if (el && name) {
        el.style.transition = 'none';
        el.style.opacity = '0';
        el.style.transform = 'translateY(16px)';
        el.offsetWidth;
        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        el.style.opacity = '1';
        el.style.transform = 'none';
      }
    });
  });
</script>
