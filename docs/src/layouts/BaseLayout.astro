---
import { getLocaleFromPath } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const locale = getLocaleFromPath(Astro.url.pathname);
const defaultDesc = locale === 'ja'
  ? 'HTMLだけでアニメーション。Anti-FOUC内蔵。3KB未満。'
  : 'Animate with just HTML. Built-in anti-FOUC protection. Under 3KB.';
const { title, description = defaultDesc, lang } = Astro.props;
const htmlLang = lang || locale;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
---

<!doctype html>
<html lang={htmlLang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${Astro.site}data-anim/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${Astro.site}data-anim/og-image.png`} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Sora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- data-anim library (stub) -->
    <script is:inline src={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}data-anim.js`}></script>

    <title>{title}</title>
  </head>
  <body class="bg-bg text-text min-h-screen">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
